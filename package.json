{
  "name": "juice-toast",
  "version": "2.0.0-beta.1",
  "description": "Zero dependency JavaScript toast notification library with animations, dark mode, auto CSS injection, and mobile support",
  "keywords": [
    "toast",
    "toast-js",
    "toast-notification",
    "toast-notification-js",
    "javascript-toast",
    "toast-library",
    "popup-notification",
    "ui-toast",
    "alert-replacement",
    "notification-library",
    "vanilla-js-toast",
    "frontend-ui",
    "browser-notification"
  ],
  "license": "Atrsofer-1.0",
  "author": "KhairyK",
  "homepage": "https://github.com/KhairyK/juiceToast",
  "bugs": {
    "url": "https://github.com/KhairyK/juiceToast/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KhairyK/juiceToast.git"
  },
  "funding": "https://patreon.com/Khairy47",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "format": "npx prettier --write src/",
    "build": "npx rollup -c"
  },
  "module": "dist/juice-toast.esm.js",
  "types": "dist/juice-toast.d.ts",
  "exports": {
    ".": {
      "import": "./dist/juice-toast.esm.js",
      "types": "./dist/juice-toast.d.ts",
      "require": "./dist/juice-toast.umd.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE",
    "README.md",
    "CONTRIBUTING.md",
    "Notice.md",
    "NEW_FUNCTION.md",
    "API.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "unpkg": "dist/juice-toast.esm.js",
  "jsdelivr": "dist/juice-toast.esm.js",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "esbuild": "^0.27.3",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "@juice-toast/plugins-react": "^1.0.0-beta.2"
  }
}
